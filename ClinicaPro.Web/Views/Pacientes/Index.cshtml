@model IEnumerable<ClinicaPro.Core.Entities.Paciente>

@{
    ViewData["Title"] = "Lista de Pacientes";
}

<div class="container-fluid mt-5">

    <div class="d-flex justify-content-start align-items-center mb-3">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-fill-add"></i> Novo Paciente
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Nome</th>
                    <th>Data de Nascimento</th>
                    <th>CPF</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model)
{
                <tr>
                    <td>@item.Nome</td>
                    <td>@item.DataNascimento.ToShortDateString()</td>
                    <td>@item.CPF</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">
                            <i class="bi bi-info-circle"></i> Detalhes
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Excluir
                        </a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>

</div>

<style>
    /* Aproxima ainda mais as colunas, sem diminuir fonte ou botões */
    .table td, .table th {
        padding-left: 0.25rem;  /* menos espaço à esquerda */
        padding-right: 0.25rem; /* menos espaço à direita */
        vertical-align: middle; 
    }

    /* Coluna de ações um pouco mais próxima do CPF */
    .table td.text-center {
        padding-left: 0.15rem; 
        padding-right: 0.15rem; 
    }

    /* Mantém a distância mínima entre os botões */
    .table td.text-center .btn {
        margin-right: 0.2rem; 
    }

    /* Botão Novo Paciente padrão */
    .btn-primary {
        color: #fff;
        background-color: #1b6ec2;
        border-color: #1861ac;
    }
</style>
