@model IEnumerable<ClinicaPro.Core.Entities.Consulta>

@{
    ViewData["Title"] = "Consultas";
}

<div class="container-fluid mt-5">

    <!-- Botão Nova Consulta -->
    <div class="d-flex justify-content-start align-items-center mb-3"> 
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-calendar-plus"></i> Nova Consulta
        </a>
    </div>

    <!-- Tabela responsiva -->
    <div class="table-responsive shadow-sm rounded"> 
        <table class="table table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().DataHora)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Status)</th>
                    <th>Tipo Atendimento</th>
                    <th>Convênio</th>
                    <th>Paciente</th>
                    <th>Médico</th>
                    <th>@Html.DisplayNameFor(model => model.First().Observacoes)</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td>@item.DataHora.ToString("g")</td>
                        <td>@item.Status</td>
                        <td>@(item.ConvenioMedicoId.HasValue ? "Convênio" : "Particular")</td>
                        <td>@(item.ConvenioMedico?.Nome ?? "-")</td>
                        <td>@(item.Paciente?.Nome ?? "N/A")</td>
                        <td>@(item.Medico?.Nome ?? "N/A")</td>
                        <td>@item.Observacoes</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">
                                <i class="bi bi-info-circle"></i> Detalhes
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Excluir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* Aproxima horizontalmente todas as colunas da tabela */
    .table td, .table th {
        padding-left: 0.25rem;  
        padding-right: 0.25rem; 
        vertical-align: middle; 
    }

    /* Coluna de ações mais próxima da coluna anterior */
    .table td.text-center {
        padding-left: 0.15rem; 
        padding-right: 0.15rem; 
    }

    /* Botões de ações com pequena distância entre eles */
    .table td.text-center .btn {
        margin-right: 0.2rem; 
    }

    /* Botão Novo Consulta padrão */
    .btn-primary {
        color: #fff;
        background-color: #1b6ec2;
        border-color: #1861ac;
    }
</style>
