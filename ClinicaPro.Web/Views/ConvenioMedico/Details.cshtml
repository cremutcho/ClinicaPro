@model ClinicaPro.Core.Entities.ConvenioMedico

@{
    ViewData["Title"] = "Detalhes do Convênio";
}

<h2 class="mb-4">Detalhes do Convênio</h2>

<div class="card p-4">

    <dl class="row">

        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Nome</dt>
        <dd class="col-sm-9">@Model.Nome</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            @if (Model.Ativo)
            {
                <span class="badge bg-success">Ativo</span>
            }
            else
            {
                <span class="badge bg-secondary">Inativo</span>
            }
        </dd>

        <dt class="col-sm-3">Data Cadastro</dt>
        <dd class="col-sm-9">@Model.DataCadastro.ToString("dd/MM/yyyy")</dd>

    </dl>

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>

        <a asp-action="Index" class="btn btn-secondary">
            Voltar
        </a>
    </div>

</div>
