@model IEnumerable<ClinicaPro.Core.Entities.Medico>

@{
    ViewData["Title"] = "Médicos";
}

<div class="container-fluid mt-5">

    <div class="d-flex justify-content-start align-items-center mb-3"> 
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Novo Médico
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-primary">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().Nome)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CRM)</th>
                    <th>Especialidade</th>
                    <th>@Html.DisplayNameFor(model => model.First().Email)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Telefone)</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Nome)</td>
                        <td>@Html.DisplayFor(modelItem => item.CRM)</td>
                        <td>@(item.Especialidade?.Nome ?? "Nenhuma")</td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.Telefone)</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">
                                <i class="bi bi-info-circle"></i> Detalhes
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Excluir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<style>
    /* Aproxima horizontalmente todas as colunas */
    .table td, .table th {
        padding-left: 0.25rem;  
        padding-right: 0.25rem; 
        vertical-align: middle; 
    }

    /* Coluna de ações mais próxima da coluna anterior */
    .table td.text-center {
        padding-left: 0.15rem; 
        padding-right: 0.15rem; 
    }

    /* Botões de ações com pequena distância entre eles */
    .table td.text-center .btn {
        margin-right: 0.2rem; 
    }

    /* Mantém padrão do botão primário */
    .btn-primary {
        color: #fff;
        background-color: #1b6ec2;
        border-color: #1861ac;
    }
</style>
